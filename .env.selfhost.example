# Elmental V2 self-host deployment template.
# Copy to .env.selfhost and fill values on the deployment host.
# Never commit .env.selfhost.

# Public HTTPS origin used by Telegram WebApp, browser users, Caddy, and TMA build args.
PUBLIC_HOST=elmental.example.com
PUBLIC_ORIGIN=https://elmental.example.com

# Docker host ports. Keep defaults for direct public Caddy TLS.
HTTP_PORT=80
HTTPS_PORT=443

# SpacetimeDB runtime.
SPACETIME_IMAGE=clockworklabs/spacetime:latest
SPACETIME_DB=elmental-v2
SPACETIME_LOCAL_PORT=3000

# TMA build-time config.
VITE_BOT_FALLBACK_SECONDS=0

# Telegram bot and payments service secrets.
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBAPP_URL=https://elmental.example.com/
PAYMENT_PAYLOAD_SECRET=replace_with_32_plus_random_chars
PAYMENTS_WEBHOOK_SECRET=replace_with_random_webhook_secret

# Comma-separated Telegram numeric user IDs allowed to open /admin.
ADMIN_TELEGRAM_IDS=

# Durable admin audit log path inside the payments container.
ADMIN_AUDIT_LOG_PATH=/data/admin-audit-events.jsonl

# Used only when PAYMENTS_SPACETIME_TOKEN is absent. Credits EML through backend SQL and stores a local receipt log.
PAYMENTS_FALLBACK_LEDGER_PATH=/data/payment-fallback-ledger.jsonl

# Critical: must be a JWT trusted by the self-hosted SpacetimeDB instance.
# Required claims:
#   iss: elmental-payments
#   sub: payments-service
#   aud includes: elmental-v2-payments
# Without this token the payments service uses the SQL fallback path below.
PAYMENTS_SPACETIME_TOKEN=

# Optional SQL bearer token for the local self-host fallback paths.
# Needed for SQL fallback crediting, admin balance edits, and fallback Stars refunds
# when PAYMENTS_SPACETIME_TOKEN is not configured.
PAYMENTS_SQL_TOKEN=

# Comma-separated origins accepted by the payments API CORS layer.
PAYMENTS_ALLOWED_ORIGINS=https://elmental.example.com
