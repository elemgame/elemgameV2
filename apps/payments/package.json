{
  "name": "@elmental/payments",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/index.js",
    "start": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "spacetimedb": "^2.2.0",
    "undici": "^6.19.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "0.21.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
